# ============================================================================
# NanoClaw Environment Configuration
# ============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env:        cp .env.example .env
#   2. Fill in the required values below (marked REQUIRED)
#   3. Build and start everything:    ./start.sh
#
# AUTHENTICATION (pick ONE of these — at least one is required):
#   - Option A: Claude subscription token from `claude setup-token`
#     Set CLAUDE_CODE_OAUTH_TOKEN below
#   - Option B: Anthropic API key from https://console.anthropic.com/
#     Set ANTHROPIC_API_KEY below
#
# CHANNELS (optional — add tokens for each channel you want to use):
#   - Telegram: Create a bot via @BotFather, get the token, then send
#     /chatid to your bot to get your chat ID
#   - Slack/Discord: See project docs for setup instructions
#
# ============================================================================

# --- Required: Assistant Identity ---

# Your assistant's name (used for trigger pattern @Name and message formatting)
ASSISTANT_NAME="Honoré"

# --- Required: Authentication (pick ONE) ---

# Option A: Claude subscription token (from `claude setup-token`)
#CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API key (from https://console.anthropic.com/)
#ANTHROPIC_API_KEY=

# --- Optional: Additional AI Provider Keys ---
# Names MUST match providers/registry.yaml (api_key_env) and
# controller/podman_runner.py (_API_KEY_ENVS). Wrong names are silently ignored.

#DEEPSEEK_API_KEY=
#OPENAI_API_KEY=
#GEMINI_API_KEY=

# --- Container Runtime ---

# Which runtime to use: docker, podman, or container (Apple Container)
# Auto-detected if not set.
CONTAINER_RUNTIME=podman

# --- Credential Proxy (Docker/Podman only) ---

# OneCLI gateway URL — injects secrets into containers at request time
# Not needed if using Apple Container (secrets go in .env directly)
#ONECLI_URL=http://127.0.0.1:10254

# --- Optional ---

# Timezone (IANA identifier, auto-detected if not set)
#TZ=America/New_York

# Container image (default: nanoclaw-agent:latest)
CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout in ms (default: 1800000 = 30 min)
CONTAINER_TIMEOUT=1800000

# Idle timeout in ms — close container stdin after inactivity (default: 1800000)
IDLE_TIMEOUT=1800000

# Max concurrent agent containers (default: 5)
#MAX_CONCURRENT_CONTAINERS=5

# Max messages batched per agent prompt (default: 10)
#MAX_MESSAGES_PER_PROMPT=10

# --- Channel Tokens (added by /add-telegram, /add-slack, etc.) ---

#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=
#SLACK_BOT_TOKEN=
#SLACK_APP_TOKEN=
#DISCORD_BOT_TOKEN=
